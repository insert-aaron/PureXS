<Window x:Class="PureXS.Views.ImageEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureXS — Preview / Edit"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        ShowInTaskbar="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="SliderTrackBg" Color="#2A2A4A" />
        <SolidColorBrush x:Key="SliderThumb" Color="#4FC3F7" />

        <Style x:Key="EditSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="-100" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="Height" Value="22" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <!-- ═══ Left: Image Preview ═══ -->
        <Border Grid.Column="0" Background="#0A0A0A" CornerRadius="8"
                Margin="8" ClipToBounds="True">
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Border>

        <!-- ═══ Right: Edit Sidebar ═══ -->
        <Border Grid.Column="1" Background="#111827" CornerRadius="8" Margin="0,8,8,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <StackPanel Margin="16">

                    <TextBlock Text="Edit Image"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,16" />

                    <!-- Exposure -->
                    <TextBlock Text="Exposure" Foreground="#90A4AE" FontSize="11" Margin="0,0,0,4" />
                    <Slider x:Name="ExposureSlider"
                            Style="{StaticResource EditSlider}"
                            Value="0"
                            ValueChanged="OnSliderChanged" />
                    <TextBlock x:Name="ExposureLabel"
                               Text="0" Foreground="#546E7A" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,0,0,12" />

                    <!-- Contrast -->
                    <TextBlock Text="Contrast" Foreground="#90A4AE" FontSize="11" Margin="0,0,0,4" />
                    <Slider x:Name="ContrastSlider"
                            Minimum="30" Maximum="300" Value="100"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            Height="22"
                            ValueChanged="OnSliderChanged" />
                    <TextBlock x:Name="ContrastLabel"
                               Text="1.00" Foreground="#546E7A" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,0,0,12" />

                    <!-- Brightness -->
                    <TextBlock Text="Brightness" Foreground="#90A4AE" FontSize="11" Margin="0,0,0,4" />
                    <Slider x:Name="BrightnessSlider"
                            Style="{StaticResource EditSlider}"
                            Value="0"
                            ValueChanged="OnSliderChanged" />
                    <TextBlock x:Name="BrightnessLabel"
                               Text="0" Foreground="#546E7A" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,0,0,12" />

                    <!-- Sharpness -->
                    <TextBlock Text="Sharpness" Foreground="#90A4AE" FontSize="11" Margin="0,0,0,4" />
                    <Slider x:Name="SharpnessSlider"
                            Minimum="0" Maximum="300" Value="0"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            Height="22"
                            ValueChanged="OnSliderChanged" />
                    <TextBlock x:Name="SharpnessLabel"
                               Text="0.0" Foreground="#546E7A" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,0,0,12" />

                    <!-- Invert -->
                    <CheckBox x:Name="InvertCheck"
                              Content="Invert"
                              Foreground="#90A4AE"
                              FontSize="11"
                              Margin="0,4,0,20"
                              Checked="OnSliderChanged"
                              Unchecked="OnSliderChanged" />

                    <!-- ═══ Action Buttons ═══ -->
                    <Button Content="Reset All"
                            Click="OnReset"
                            Padding="12,10"
                            FontSize="12"
                            Foreground="White"
                            Cursor="Hand"
                            Margin="0,0,0,8">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#37474F" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#455A64" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Apply &amp; Close"
                            Click="OnApply"
                            Padding="12,12"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Cursor="Hand"
                            Margin="0,0,0,8">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#1565C0" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#1976D2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Save As PNG"
                            Click="OnSavePng"
                            Padding="12,10"
                            FontSize="12"
                            Foreground="White"
                            Cursor="Hand"
                            Margin="0,0,0,8">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#1B5E20" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#2E7D32" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Cancel"
                            Click="OnCancel"
                            Padding="12,10"
                            FontSize="12"
                            Foreground="White"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#424242" CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#616161" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
