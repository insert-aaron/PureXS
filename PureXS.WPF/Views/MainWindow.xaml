<Window x:Class="PureXS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PureXS.Models"
        Title="PureXS — Sirona ORTHOPHOS XG"
        Width="1280" Height="800"
        MinWidth="1050" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Resources>
        <!-- Accent colors -->
        <Color x:Key="AccentColor">#0F3460</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="PanelBg" Color="#16213E" />
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextSecondary" Color="#8892A0" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2A2A4A" />
        <SolidColorBrush x:Key="FieldBg" Color="#111128" />

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#111128" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#2A2A4A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CaretBrush" Value="#E0E0E0" />
        </Style>

        <!-- Expose button style -->
        <Style x:Key="ExposeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#C0392B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="40,20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#E74C3C"
                                BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A93226" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#3A3A4A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A4A5A" />
                                <Setter Property="Foreground" Value="#6A6A7A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard button style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A4A7A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2A2A3A" />
                                <Setter Property="Foreground" Value="#5A5A6A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar button style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="#37474F"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#455A64"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#455A64" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2A2A3A" />
                                <Setter Property="Foreground" Value="#5A5A6A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Heartbeat pulse animation -->
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation Storyboard.TargetName="HeartbeatDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.3" Duration="0:0:0.08"
                             AutoReverse="True" />
        </Storyboard>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- ── Bottom Status Bar ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#111128"
                Padding="14,8"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding PatientBanner}"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="12" />
        </Border>

        <!-- ── Main Content ──────────────────────────────────────────────── -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Column 0: Patient Avatar Dock ─────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBg}"
                    CornerRadius="12"
                    Margin="0,0,8,0"
                    Padding="6"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsDockVisible, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Search box at top -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding PureChartSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             FontSize="10"
                             Padding="6,5"
                             Margin="0,0,0,4" />

                    <!-- Status text -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding PureChartStatus}"
                               Foreground="{Binding PureChartStatusColor}"
                               FontSize="9"
                               TextAlignment="Center"
                               Margin="0,0,0,6" />

                    <!-- Patient avatars (scrollable) -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PureChartResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PureChartPatient}">
                                    <Button Command="{Binding DataContext.SelectPatientCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand"
                                            Margin="0,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="avatarBorder"
                                                        Width="80" Height="80"
                                                        CornerRadius="14"
                                                        Background="#111128"
                                                        BorderBrush="#2A2A4A"
                                                        BorderThickness="2"
                                                        ClipToBounds="True"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Border.RenderTransform>
                                                    <Grid>
                                                        <!-- Profile picture -->
                                                        <Image Source="{Binding ProfileImage}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />

                                                        <!-- Fallback initials when no image -->
                                                        <Border Background="#0F3460">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasProfileImage}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Initials}"
                                                                       Foreground="White"
                                                                       FontSize="22"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>

                                                        <!-- Selection highlight -->
                                                        <Border x:Name="selectionRing"
                                                                CornerRadius="14"
                                                                BorderThickness="0"
                                                                BorderBrush="#4FC3F7"
                                                                IsHitTestVisible="False" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <!-- Hover: scale up -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="avatarBorder" Property="BorderBrush" Value="#4FC3F7" />
                                                        <Setter TargetName="avatarBorder" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.08" ScaleY="1.08" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <!-- Hover tooltip: magnified view with patient details -->
                                        <Button.ToolTip>
                                            <ToolTip Placement="Right"
                                                     HasDropShadow="True">
                                                <ToolTip.Style>
                                                    <Style TargetType="ToolTip">
                                                        <Setter Property="Background" Value="#1E2A44" />
                                                        <Setter Property="BorderBrush" Value="#4FC3F7" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToolTip">
                                                                    <Border Background="#1E2A44"
                                                                            BorderBrush="#4FC3F7"
                                                                            BorderThickness="1"
                                                                            CornerRadius="12"
                                                                            Padding="14"
                                                                            MaxWidth="320">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToolTip.Style>
                                                <StackPanel Width="260">
                                                    <!-- Large profile picture -->
                                                    <Border Width="180" Height="180"
                                                            CornerRadius="16"
                                                            Background="#111128"
                                                            ClipToBounds="True"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,0,0,12">
                                                        <Grid>
                                                            <Image Source="{Binding ProfileImage}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <Border Background="#0F3460">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasProfileImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           Foreground="White"
                                                                           FontSize="48"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Name -->
                                                    <TextBlock Foreground="White"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextAlignment="Center"
                                                               Margin="0,0,0,2">
                                                        <Run Text="{Binding FirstName, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding LastName, Mode=OneWay}" />
                                                    </TextBlock>

                                                    <!-- MRN -->
                                                    <TextBlock Text="{Binding MedicalRecordNumber}"
                                                               Foreground="#4FC3F7"
                                                               FontSize="11"
                                                               FontFamily="Consolas"
                                                               TextAlignment="Center"
                                                               Margin="0,0,0,10" />

                                                    <!-- Details grid -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="DOB"
                                                                   Foreground="#8892A0"
                                                                   FontSize="11" Margin="0,0,0,4" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   Text="{Binding Dob}"
                                                                   Foreground="#E0E0E0"
                                                                   FontSize="11" Margin="0,0,0,4" />

                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   Text="Phone"
                                                                   Foreground="#8892A0"
                                                                   FontSize="11" Margin="0,0,0,4" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                                   Text="{Binding Phone}"
                                                                   Foreground="#E0E0E0"
                                                                   FontSize="11" Margin="0,0,0,4" />

                                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                                   Text="Email"
                                                                   Foreground="#8892A0"
                                                                   FontSize="11" />
                                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                                   Text="{Binding Email}"
                                                                   Foreground="#E0E0E0"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Column 1: Controls Panel ──────────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="1"
                    Background="{StaticResource PanelBg}"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,8,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Logo / Title -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="PureXS"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold" />
                        <Button Grid.Column="1"
                                Content="History"
                                Command="{Binding OpenHistoryCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                FontSize="11"
                                Padding="10,6"
                                VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="ORTHOPHOS XG Controller"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="12"
                               Margin="0,0,0,20" />

                    <!-- ── Machine Status ─────────────────────────────────── -->
                    <TextBlock Text="MACHINE"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <Border Background="#111128"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0"
                                     Width="12" Height="12"
                                     Fill="{Binding MachineIndicator}"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MachineStatus}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <Ellipse x:Name="HeartbeatDot"
                                     Grid.Column="2"
                                     Width="8" Height="8"
                                     Fill="#27AE60"
                                     Opacity="0.3"
                                     VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,20" />

                    <!-- ── Selected Patient Card ──────────────────────────── -->
                    <TextBlock Text="SELECTED PATIENT"
                               Foreground="#81D4FA"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <Border Background="#111128"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,20"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <!-- No patient selected -->
                            <TextBlock Text="Select a patient from the dock"
                                       Foreground="#5A5A6A"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Patient info when selected -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,2">
                                    <Run Text="{Binding SelectedPatient.FirstName, Mode=OneWay}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding SelectedPatient.LastName, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Text="{Binding SelectedPatient.MedicalRecordNumber}"
                                           Foreground="#4FC3F7"
                                           FontSize="11"
                                           FontFamily="Consolas"
                                           Margin="0,0,0,6" />
                                <TextBlock Foreground="{StaticResource TextSecondary}"
                                           FontSize="11">
                                    <Run Text="DOB: " />
                                    <Run Text="{Binding SelectedPatient.Dob, Mode=OneWay}" Foreground="{StaticResource TextPrimary}" />
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,2,0,0">
                                    <Run Text="Phone: " />
                                    <Run Text="{Binding SelectedPatient.Phone, Mode=OneWay}" Foreground="{StaticResource TextPrimary}" />
                                </TextBlock>

                                <!-- Change Patient button -->
                                <Button Content="Change Patient"
                                        Command="{Binding ChangePatientCommand}"
                                        Margin="0,10,0,0"
                                        Padding="8,6"
                                        FontSize="11"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="#37474F"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderBrush="#455A64"
                                                    BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#455A64" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,20" />

                    <!-- ── Exam Type Selector ─────────────────────────────── -->
                    <TextBlock Text="EXAM TYPE"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding ExamTypeOptions}"
                              SelectedItem="{Binding SelectedExamType}"
                              Background="#111128"
                              Foreground="#E0E0E0"
                              BorderBrush="#2A2A4A"
                              BorderThickness="1"
                              Padding="8,6"
                              FontSize="12"
                              Margin="0,0,0,20" />

                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,20" />

                    <!-- ── EXPOSE Button ───────────────────────────────────── -->
                    <Button Content="EXPOSE"
                            Command="{Binding ExposeCommand}"
                            Style="{StaticResource ExposeButtonStyle}"
                            HorizontalAlignment="Stretch" />
                    <TextBlock Text="Requires: patient selected + machine ready"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />

                    <!-- ── kV Gauge (visible during expose) ──────────────────── -->
                    <Border Margin="0,20,0,0"
                            Background="#111128"
                            CornerRadius="6"
                            Padding="12,8"
                            Visibility="{Binding IsKvActive, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="{Binding KvDisplayText}"
                                           Foreground="#4FC3F7"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Left" />
                                <TextBlock Foreground="{StaticResource TextSecondary}"
                                           FontSize="10"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom">
                                    <Run Text="Peak: " />
                                    <Run Text="{Binding KvPeak, StringFormat='{}{0:F1}'}" />
                                    <Run Text=" kV" />
                                </TextBlock>
                            </Grid>
                            <ProgressBar Height="6"
                                         Value="{Binding KvGaugePercent}"
                                         Minimum="0" Maximum="1"
                                         Foreground="#4FC3F7"
                                         Background="#2A2A4A" />
                        </StackPanel>
                    </Border>

                    <!-- ── Scanline Preview (visible during expose) ──────────── -->
                    <Border Margin="0,12,0,0"
                            Background="#0A0A0A"
                            CornerRadius="6"
                            Padding="4"
                            Visibility="{Binding IsKvActive, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="4,2,4,4">
                                <TextBlock Text="Scanline Preview"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Left" />
                                <TextBlock Foreground="{StaticResource TextSecondary}"
                                           FontSize="10"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Right">
                                    <Run Text="{Binding ScanlineCount, Mode=OneWay}" />
                                    <Run Text=" lines" />
                                </TextBlock>
                            </Grid>
                            <Image Source="{Binding ScanlinePreviewImage}"
                                   Height="150"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!-- ── Column 2: Image Display ───────────────────────────────── -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBg}"
                    CornerRadius="12"
                    Padding="20"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="X-RAY IMAGE"
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14" />

                    <!-- Image area -->
                    <Border Grid.Row="1" Background="#0D0D1A" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            ClipToBounds="True" x:Name="ImageContainer">
                        <Grid>
                            <!-- Placeholder when no image -->
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding ReceivedImage, Converter={StaticResource BoolToVis}, ConverterParameter=invert, FallbackValue=Visible}">
                                <TextBlock Text="&#xE8B8;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="64"
                                           Foreground="#2A2A4A"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="No image received"
                                           Foreground="#3A3A5A"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0" />
                            </StackPanel>

                            <!-- Interactive image viewer -->
                            <Image x:Name="XrayImage"
                                   Source="{Binding DisplayImage}"
                                   Stretch="Uniform"
                                   RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="ImageScale"
                                                       ScaleX="{Binding ZoomLevel}"
                                                       ScaleY="{Binding ZoomLevel}" />
                                        <TranslateTransform x:Name="ImageTranslate"
                                                           X="{Binding PanX}"
                                                           Y="{Binding PanY}" />
                                    </TransformGroup>
                                </Image.RenderTransform>
                            </Image>

                            <!-- Scan progress overlay -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding IsScanInProgress, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE8B8;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                           Foreground="#FF9800" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding ScanProgressText}" Foreground="#FF9800"
                                           FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                <!-- Indeterminate progress bar -->
                                <ProgressBar IsIndeterminate="True" Height="4" Width="200" Margin="0,10,0,0"
                                             Foreground="#FF9800" Background="#2A2A4A" />
                            </StackPanel>

                            <!-- Preview / Edit button overlay (top-right) -->
                            <Button Content="Preview / Edit"
                                    Command="{Binding OpenPreviewEditCommand}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,10,10,0"
                                    Padding="14,7"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Cursor="Hand"
                                    Visibility="{Binding IsReviewingImage, Converter={StaticResource BoolToVis}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="#CC1565C0"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#1976D2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Zoom percentage overlay -->
                            <TextBlock Text="{Binding ZoomPercentText}"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"
                                       FontFamily="Consolas"
                                       Background="#99111128"
                                       Padding="6,3"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,8,8" />
                        </Grid>
                    </Border>

                    <!-- Review controls (visible only when reviewing) -->
                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Visibility="{Binding IsReviewingImage, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <!-- Review status -->
                            <TextBlock Text="{Binding ReviewStatus}"
                                       Foreground="{Binding ReviewStatusColor}"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12" />

                            <!-- Confirm + Retry + Retake buttons -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Confirm & Send -->
                                <Button Grid.Column="0"
                                        Content="Confirm &amp; Send to PureChart"
                                        Command="{Binding ConfirmImageCommand}"
                                        Padding="16,12"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="#1B5E20"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderBrush="#2E7D32"
                                                    BorderThickness="2">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#2E7D32" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="border" Property="Background" Value="#2A2A3A" />
                                                    <Setter Property="Foreground" Value="#5A5A6A" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Retry Upload (visible only when upload failed) -->
                                <Button Grid.Column="2"
                                        Content="Retry Upload"
                                        Command="{Binding RetryUploadCommand}"
                                        Padding="16,12"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Visibility="{Binding IsUploadFailed, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="#E65100"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderBrush="#FF6D00"
                                                    BorderThickness="2">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF6D00" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="border" Property="Background" Value="#2A2A3A" />
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#4A4A5A" />
                                                    <Setter Property="Foreground" Value="#5A5A6A" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Retake -->
                                <Button Grid.Column="4"
                                        Content="Retake"
                                        Command="{Binding RetakeCommand}"
                                        Padding="16,12"
                                        FontSize="14"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                    Background="#37474F"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}"
                                                    BorderBrush="#455A64"
                                                    BorderThickness="1">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#455A64" />
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="border" Property="Background" Value="#2A2A3A" />
                                                    <Setter Property="Foreground" Value="#5A5A6A" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- ── Post-Expose Toolbar ────────────────────── -->
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,14,0,14" />

                            <!-- Brightness -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Brightness"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        Minimum="-80" Maximum="80"
                                        Value="{Binding Brightness}"
                                        Foreground="#4FC3F7"
                                        VerticalAlignment="Center" />
                            </Grid>

                            <!-- Contrast -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Contrast"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        Minimum="0.3" Maximum="3.0"
                                        Value="{Binding Contrast}"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="False"
                                        Foreground="#4FC3F7"
                                        VerticalAlignment="Center" />
                            </Grid>

                            <!-- Action buttons row -->
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Reset"
                                        Command="{Binding ResetAdjustmentsCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Fit"
                                        Command="{Binding FitToCanvasCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="Save PNG"
                                        Command="{Binding SavePngCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="New Patient"
                                        Command="{Binding NewPatientCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ── Toast Notification Overlay ──────────────────────────────────── -->
    <ItemsControl ItemsSource="{Binding ActiveToasts}"
                  IsHitTestVisible="False"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,24,24">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border x:Name="ToastBorder"
                        CornerRadius="8"
                        Padding="16,10"
                        Margin="0,0,0,8"
                        MinWidth="260"
                        MaxWidth="400"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform X="40" />
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <!-- Slide in from right -->
                                    <DoubleAnimation Storyboard.TargetName="ToastBorder"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="40" To="0"
                                                     Duration="0:0:0.25"
                                                     DecelerationRatio="0.6" />
                                    <!-- Fade in -->
                                    <DoubleAnimation Storyboard.TargetName="ToastBorder"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0" To="0.95"
                                                     Duration="0:0:0.25" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#2196F3" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="success">
                                    <Setter Property="Background" Value="#4CAF50" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="warning">
                                    <Setter Property="Background" Value="#FF9800" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="error">
                                    <Setter Property="Background" Value="#F44336" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Message}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
    </Grid>
</Window>
