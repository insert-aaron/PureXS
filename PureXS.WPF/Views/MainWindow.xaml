<Window x:Class="PureXS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PureXS.Models"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        ui:ThemeManager.IsThemeAware="True"
        Title="PureXS — Sirona ORTHOPHOS XG"
        Width="1280" Height="800"
        MinWidth="1050" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <CubicEase x:Key="EaseOut" EasingMode="EaseOut" />

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource FieldBg}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}" />
        </Style>

        <!-- Expose button style -->
        <Style x:Key="ExposeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DangerBg}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="40,20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource DangerBorder}"
                                BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DisabledBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard button style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBtnBg}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource BorderPrimary}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar button style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ToolbarBtnBg}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource ToolbarBtnBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ToolbarBtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green button style (Set Patient, Confirm, New Patient) -->
        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource GreenBtnBg}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource GreenBtnBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource GreenBtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Purple button style (Connect, View DICOM) -->
        <Style x:Key="PurpleButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource PurpleBtnBg}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource PurpleBtnBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PurpleBtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Blue button style (Save PNG) -->
        <Style x:Key="BlueButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource BlueBtnBg}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource BlueBtnBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource BlueBtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Orange button style (Retry Upload) -->
        <Style x:Key="OrangeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource OrangeBtnBg}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource OrangeBtnBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource OrangeBtnHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red expose toolbar button -->
        <Style x:Key="ExposeToolbarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource DangerBg}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource DangerBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DisabledBorder}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Heartbeat pulse animation -->
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation Storyboard.TargetName="HeartbeatDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.3" Duration="0:0:0.08"
                             AutoReverse="True" />
        </Storyboard>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- ================================================================ -->
        <!-- TOP TOOLBAR — Gradient bar with brand accent                     -->
        <!-- ================================================================ -->
        <Border DockPanel.Dock="Top"
                Height="50"
                Padding="14,0"
                BorderBrush="{DynamicResource BorderPrimary}"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{DynamicResource TopBarStart}" Offset="0" />
                    <GradientStop Color="{DynamicResource TopBarMid}" Offset="0.5" />
                    <GradientStop Color="{DynamicResource TopBarEnd}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- PureXS logo -->
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />  <!-- Connect -->
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />  <!-- Expose -->
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />  <!-- History -->
                    <ColumnDefinition Width="*" />      <!-- spacer -->
                    <ColumnDefinition Width="Auto" />  <!-- API status -->
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="Auto" />  <!-- Theme toggle -->
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />  <!-- Window controls -->
                </Grid.ColumnDefinitions>

                <!-- PureXS logo text -->
                <TextBlock Grid.Column="0"
                           Text="PureXS"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />

                <!-- Connect to Device -->
                <Button Grid.Column="2"
                        Content="{Binding ConnectButtonText}"
                        Command="{Binding ToggleConnectionCommand}"
                        IsEnabled="{Binding IsConnectEnabled}"
                        Style="{StaticResource PurpleButtonStyle}"
                        VerticalAlignment="Center" />

                <!-- Expose (toolbar size) -->
                <Button Grid.Column="4"
                        Command="{Binding ExposeCommand}"
                        Style="{StaticResource ExposeToolbarButtonStyle}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2622; " FontSize="13" />
                        <TextBlock Text="EXPOSE" FontSize="13" FontWeight="Bold" />
                    </StackPanel>
                </Button>

                <!-- History -->
                <Button Grid.Column="6"
                        Command="{Binding OpenHistoryCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4C1; " FontSize="12" />
                        <TextBlock Text="History" FontSize="12" />
                    </StackPanel>
                </Button>

                <!-- API / connection status (right-aligned) -->
                <StackPanel Grid.Column="8"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding MachineIndicator}"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding MachineStatus}"
                               Foreground="{DynamicResource Accent300}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               MaxWidth="200"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Theme toggle button -->
                <Button x:Name="ThemeToggleBtn"
                        Grid.Column="10"
                        Content="&#xE793;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Foreground="White"
                        ToolTip="Toggle Light / Dark Mode"
                        Width="36" Height="30"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource WinControlHover}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Window controls: Minimize, Maximize, Close -->
                <StackPanel Grid.Column="12"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Minimize -->
                    <Button x:Name="MinimizeBtn"
                            Content="&#xE921;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="White"
                            Width="36" Height="30"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource WinControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Maximize/Restore -->
                    <Button x:Name="MaximizeBtn"
                            Content="&#xE922;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="White"
                            Width="36" Height="30"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource WinControlHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Close -->
                    <Button x:Name="CloseBtn"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Foreground="White"
                            Width="36" Height="30"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource CloseButtonHover}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- STATUS BAR (Bottom)                                              -->
        <!-- ================================================================ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource StatusBarBg}"
                Height="28"
                Padding="14,0"
                BorderBrush="{DynamicResource BorderPrimary}"
                BorderThickness="0,1,0,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Heart icon -->
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />  <!-- HB text -->
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />      <!-- Patient banner -->
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />  <!-- Expose count -->
                </Grid.ColumnDefinitions>

                <!-- Heart icon — pulses via HeartbeatColor binding -->
                <TextBlock Grid.Column="0"
                           Text="&#x2764;"
                           FontSize="12"
                           Foreground="{Binding HeartbeatColor}"
                           VerticalAlignment="Center" />

                <!-- HB status text -->
                <TextBlock Grid.Column="2"
                           Text="{Binding HbStatusText}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           FontFamily="Consolas"
                           VerticalAlignment="Center" />

                <!-- Patient banner -->
                <TextBlock Grid.Column="4"
                           Text="{Binding PatientBanner}"
                           Foreground="{DynamicResource PatientBannerFg}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- Expose count (right) -->
                <TextBlock Grid.Column="6"
                           Text="{Binding ExposeCountText, Mode=OneWay}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           FontFamily="Consolas"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ================================================================ -->
        <!-- BOTTOM TOOLBAR                                                   -->
        <!-- ================================================================ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BottomToolbarBg}"
                Padding="14,8"
                BorderBrush="{DynamicResource BorderPrimary}"
                BorderThickness="0,1,0,0">
            <StackPanel>
                <!-- Row 1: Image info + Brightness + Contrast sliders -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />      <!-- image info -->
                        <ColumnDefinition Width="70" />     <!-- brightness label -->
                        <ColumnDefinition Width="160" />    <!-- brightness slider -->
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="60" />     <!-- contrast label -->
                        <ColumnDefinition Width="160" />    <!-- contrast slider -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding ReviewStatus}"
                               Foreground="{Binding ReviewStatusColor}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Column="1"
                               Text="Brightness"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="2"
                            Minimum="-80" Maximum="80"
                            Value="{Binding Brightness}"
                            VerticalAlignment="Center" />

                    <TextBlock Grid.Column="4"
                               Text="Contrast"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <Slider Grid.Column="5"
                            Minimum="0.3" Maximum="3.0"
                            Value="{Binding Contrast}"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            VerticalAlignment="Center" />
                </Grid>

                <!-- Row 2: Action buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- Save PNG -->
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />  <!-- DICOM Folder -->
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />  <!-- View DICOM -->
                        <ColumnDefinition Width="*" />      <!-- spacer -->
                        <ColumnDefinition Width="Auto" />  <!-- New Patient -->
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />  <!-- Reset -->
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />  <!-- Fit -->
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />  <!-- Zoom % -->
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Save PNG"
                            Command="{Binding SavePngCommand}"
                            Style="{StaticResource BlueButtonStyle}"
                            Visibility="{Binding HasImage, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <Button Grid.Column="2"
                            Content="DICOM Folder"
                            Command="{Binding OpenDicomFolderCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Visibility="{Binding HasImage, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <Button Grid.Column="4"
                            Content="View DICOM"
                            Command="{Binding ViewDicomCommand}"
                            Style="{StaticResource PurpleButtonStyle}"
                            Visibility="{Binding HasImage, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    <Button Grid.Column="6"
                            Content="New Patient"
                            Command="{Binding NewPatientCommand}"
                            Style="{StaticResource GreenButtonStyle}" />

                    <Button Grid.Column="8"
                            Content="Reset"
                            Command="{Binding ResetAdjustmentsCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />

                    <Button Grid.Column="10"
                            Content="Fit"
                            Command="{Binding FitToCanvasCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />

                    <TextBlock Grid.Column="12"
                               Text="{Binding ZoomPercentText, Mode=OneWay}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- ================================================================ -->
        <!-- MAIN CONTENT (3 columns: avatar dock | left panel | image)       -->
        <!-- ================================================================ -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <!-- Avatar Dock: 88px collapsed, 280px when search expanded -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="88" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchExpanded}" Value="True">
                                    <Setter Property="Width" Value="280" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDockVisible}" Value="False">
                                    <Setter Property="Width" Value="0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="340" />  <!-- Left Panel -->
                <ColumnDefinition Width="*" />    <!-- Image Viewer -->
            </Grid.ColumnDefinitions>

            <!-- ============================================================ -->
            <!-- Column 0: Avatar Dock (88px collapsed / 280px expanded)      -->
            <!-- ============================================================ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBg}"
                    Padding="4"
                    BorderBrush="{DynamicResource BorderPrimary}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsDockVisible, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Search icon button (always visible at top) -->
                    <Button DockPanel.Dock="Top"
                            Command="{Binding ToggleSearchCommand}"
                            Cursor="Hand"
                            Margin="0,4,0,2"
                            HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="searchBtnBorder"
                                        Background="{DynamicResource FieldBg}"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        BorderBrush="{DynamicResource BorderPrimary}"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE721;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource SearchIconFg}"
                                                   VerticalAlignment="Center" />
                                        <!-- "Search" label only when expanded -->
                                        <TextBlock Text="  Search Patients"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsSearchExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="searchBtnBorder" Property="Background" Value="{DynamicResource HoverBg}" />
                                        <Setter TargetName="searchBtnBorder" Property="BorderBrush" Value="{DynamicResource DentalAccent}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Expanded search field (visible only when expanded) -->
                    <TextBox DockPanel.Dock="Top"
                             x:Name="PatientSearchBox"
                             Text="{Binding PureChartSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12"
                             Margin="0,4,0,4">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Padding" Value="8,6" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSearchExpanded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Status text -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding PureChartStatus}"
                               Foreground="{Binding PureChartStatusColor}"
                               FontSize="9"
                               TextAlignment="Center"
                               Margin="0,0,0,6" />

                    <!-- Patient avatars (scrollable) -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding PureChartResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PureChartPatient}">
                                    <Button Command="{Binding DataContext.SelectPatientCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand"
                                            Margin="0,0,0,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="avatarBorder"
                                                        CornerRadius="18"
                                                        Background="{DynamicResource FieldBg}"
                                                        BorderBrush="{DynamicResource BorderPrimary}"
                                                        BorderThickness="2"
                                                        ClipToBounds="True"
                                                        HorizontalAlignment="Stretch"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <!-- Collapsed: square tile -->
                                                            <Setter Property="Width" Value="72" />
                                                            <Setter Property="Height" Value="72" />
                                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                                            <Style.Triggers>
                                                                <!-- Expanded: full-width card -->
                                                                <DataTrigger Binding="{Binding DataContext.IsSearchExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="Width" Value="Auto" />
                                                                    <Setter Property="Height" Value="Auto" />
                                                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Border.RenderTransform>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Avatar (always visible) -->
                                                        <Grid Grid.Column="0" Width="68" Height="68">
                                                            <Image Source="{Binding ProfileImage}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <Border Background="{DynamicResource InitialsBg}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasProfileImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           Foreground="White"
                                                                           FontSize="20"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>

                                                        <!-- Patient info (only when expanded) -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsSearchExpanded, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Foreground="{DynamicResource TextPrimary}"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis">
                                                                <Run Text="{Binding FirstName, Mode=OneWay}" />
                                                                <Run Text=" " />
                                                                <Run Text="{Binding LastName, Mode=OneWay}" />
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Dob}"
                                                                       Foreground="{DynamicResource TextSecondary}"
                                                                       FontSize="10" Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding MedicalRecordNumber}"
                                                                       Foreground="{DynamicResource DentalAccent}"
                                                                       FontSize="9" FontFamily="Consolas"
                                                                       Margin="0,1,0,0" />
                                                        </StackPanel>

                                                        <!-- Selection highlight -->
                                                        <Border x:Name="selectionRing"
                                                                Grid.ColumnSpan="2"
                                                                CornerRadius="18"
                                                                BorderThickness="0"
                                                                BorderBrush="{DynamicResource SelectionRing}"
                                                                IsHitTestVisible="False" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="avatarBorder"
                                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                 To="1.04" Duration="0:0:0.15"
                                                                                 EasingFunction="{StaticResource EaseOut}" />
                                                                <DoubleAnimation Storyboard.TargetName="avatarBorder"
                                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                 To="1.04" Duration="0:0:0.15"
                                                                                 EasingFunction="{StaticResource EaseOut}" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="avatarBorder"
                                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                 To="1.0" Duration="0:0:0.15"
                                                                                 EasingFunction="{StaticResource EaseOut}" />
                                                                <DoubleAnimation Storyboard.TargetName="avatarBorder"
                                                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                 To="1.0" Duration="0:0:0.15"
                                                                                 EasingFunction="{StaticResource EaseOut}" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="avatarBorder" Property="BorderBrush" Value="{DynamicResource DentalAccent}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <!-- Hover tooltip: magnified view with patient details -->
                                        <Button.ToolTip>
                                            <ToolTip Placement="Right"
                                                     HasDropShadow="True">
                                                <ToolTip.Style>
                                                    <Style TargetType="ToolTip">
                                                        <Setter Property="Background" Value="{DynamicResource CardBg}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource DentalAccent}" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToolTip">
                                                                    <Border Background="{DynamicResource CardBg}"
                                                                            BorderBrush="{DynamicResource DentalAccent}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="12"
                                                                            Padding="14"
                                                                            MaxWidth="320">
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToolTip.Style>
                                                <StackPanel Width="260">
                                                    <!-- Large profile picture -->
                                                    <Border Width="180" Height="180"
                                                            CornerRadius="16"
                                                            Background="{DynamicResource FieldBg}"
                                                            ClipToBounds="True"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,0,0,12">
                                                        <Grid>
                                                            <Image Source="{Binding ProfileImage}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <Border Background="{DynamicResource InitialsBg}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasProfileImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Initials}"
                                                                           Foreground="White"
                                                                           FontSize="48"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Name -->
                                                    <TextBlock Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextAlignment="Center"
                                                               Margin="0,0,0,2">
                                                        <Run Text="{Binding FirstName, Mode=OneWay}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding LastName, Mode=OneWay}" />
                                                    </TextBlock>

                                                    <!-- MRN -->
                                                    <TextBlock Text="{Binding MedicalRecordNumber}"
                                                               Foreground="{DynamicResource DentalAccent}"
                                                               FontSize="11"
                                                               FontFamily="Consolas"
                                                               TextAlignment="Center"
                                                               Margin="0,0,0,10" />

                                                    <!-- Details grid -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="50" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="DOB"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="11" Margin="0,0,0,4" />
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   Text="{Binding Dob}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontSize="11" Margin="0,0,0,4" />

                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   Text="Phone"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="11" Margin="0,0,0,4" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                                   Text="{Binding Phone}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontSize="11" Margin="0,0,0,4" />

                                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                                   Text="Email"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="11" />
                                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                                   Text="{Binding Email}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- Column 1: Left Panel (280px)                                 -->
            <!-- ============================================================ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource PanelBg}"
                    Padding="14"
                    BorderBrush="{DynamicResource BorderPrimary}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- ── Machine Status ─────────────────────────────── -->
                    <TextBlock Text="MACHINE"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <Border Background="{DynamicResource FieldBg}"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Grid.Column="0"
                                     Width="12" Height="12"
                                     Fill="{Binding MachineIndicator}"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MachineStatus}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <Ellipse x:Name="HeartbeatDot"
                                     Grid.Column="2"
                                     Width="8" Height="8"
                                     Fill="{DynamicResource HeartbeatGreen}"
                                     Opacity="0.3"
                                     VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Phase label (visible during expose flow) -->
                    <TextBlock Text="{Binding PhaseLabel}"
                               Foreground="{Binding PhaseLabelColor}"
                               FontSize="10"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               Margin="0,4,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PhaseLabel}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Border Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,0,0,14" />

                    <!-- ── Patient Section ────────────────────────────── -->
                    <!-- PureChart patient list — only shown when dock is hidden (redundant otherwise) -->
                    <Border MaxHeight="220" Margin="0,0,0,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <!-- Only show when dock is hidden AND PureChart works AND no patient set -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsDockVisible}" Value="False" />
                                            <Condition Binding="{Binding IsManualEntryMode}" Value="False" />
                                            <Condition Binding="{Binding IsPatientSet}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding PureChartResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:PureChartPatient}">
                                        <Button Command="{Binding DataContext.SelectPatientCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                Margin="0,0,0,2">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="ptRow"
                                                            Background="{DynamicResource FieldBg}"
                                                            CornerRadius="6"
                                                            Padding="8,6"
                                                            BorderBrush="{DynamicResource BorderPrimary}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="36" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Small avatar -->
                                                            <Border Grid.Column="0" Width="32" Height="32"
                                                                    CornerRadius="16" Background="{DynamicResource InitialsBg}"
                                                                    ClipToBounds="True">
                                                                <Grid>
                                                                    <Image Source="{Binding ProfileImage}"
                                                                           Stretch="UniformToFill" />
                                                                    <Border Background="{DynamicResource InitialsBg}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasProfileImage}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding Initials}"
                                                                                   Foreground="White" FontSize="11"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                            <!-- Name + DOB -->
                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <Run Text="{Binding FirstName, Mode=OneWay}" />
                                                                    <Run Text=" " />
                                                                    <Run Text="{Binding LastName, Mode=OneWay}" />
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Dob}" FontSize="9"
                                                                           Foreground="{DynamicResource TextSecondary}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ptRow" Property="Background" Value="{DynamicResource HoverBg}" />
                                                            <Setter TargetName="ptRow" Property="BorderBrush" Value="{DynamicResource DentalAccent}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- ══ Manual entry fallback (shown when PureChart API fails) ══ -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsManualEntryMode}" Value="True" />
                                            <Condition Binding="{Binding IsPatientSet}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="First:" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding PtFirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Tag="First name" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Last:" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding PtLastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Tag="Last name" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DOB:" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding PtDob, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Tag="MM/DD/YYYY" />
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ID:" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding PtId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}" Tag="(auto if blank)" />
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding SetPatientCommand}" Style="{StaticResource GreenButtonStyle}" Padding="10,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2713; " />
                                    <TextBlock Text="Set Patient" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding ClearPatientCommand}" Style="{StaticResource ToolbarButtonStyle}" Padding="10,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2717; " />
                                    <TextBlock Text="Clear" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding PatientFormStatus}" Foreground="{Binding PatientFormStatusColor}" FontSize="11" Margin="0,0,0,4" />
                    </StackPanel>

                    <!-- Selected Patient Card (visible when IS set) -->
                    <Border Margin="0,0,0,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPatientSet}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border Background="{DynamicResource FieldBg}"
                                CornerRadius="10"
                                Padding="14"
                                BorderBrush="{DynamicResource BorderPrimary}"
                                BorderThickness="1">
                            <Grid>
                                <!-- No patient selected (PureChart) -->
                                <TextBlock Text="Select a patient from the dock"
                                           Foreground="{DynamicResource DisabledText}"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Patient info when selected (rich profile card) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 64x64 Avatar circle -->
                                        <Border Grid.Column="0"
                                                Width="64" Height="64"
                                                CornerRadius="32"
                                                Background="{DynamicResource InitialsBg}"
                                                BorderBrush="{DynamicResource AvatarBorder}"
                                                BorderThickness="2"
                                                ClipToBounds="True">
                                            <Grid>
                                                <!-- Profile picture (if available) -->
                                                <Image Source="{Binding SelectedPatient.ProfileImage, Mode=OneWay}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <!-- Initials fallback -->
                                                <Border Background="{DynamicResource InitialsBg}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedPatient.HasProfileImage, Mode=OneWay}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding SelectedPatient.Initials, Mode=OneWay}"
                                                               Foreground="{DynamicResource Accent300}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Name + details -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding SelectedPatient.FirstName, Mode=OneWay}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding SelectedPatient.LastName, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding SelectedPatient.MedicalRecordNumber, Mode=OneWay}"
                                                       Foreground="{DynamicResource DentalAccent}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Details grid -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="DOB"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11" Margin="0,0,0,3" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding SelectedPatient.Dob, Mode=OneWay}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="11" Margin="0,0,0,3" />

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Phone"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11" Margin="0,0,0,3" />
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding SelectedPatient.Phone, Mode=OneWay}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="11" Margin="0,0,0,3" />

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Email"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11" />
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{Binding SelectedPatient.Email, Mode=OneWay}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>

                                    <!-- Change Patient button -->
                                    <Button Content="Change Patient"
                                            Command="{Binding ChangePatientCommand}"
                                            Margin="0,6,0,0"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Padding="8,6"
                                            FontSize="11" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <Border Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,10,0,14" />

                    <!-- ── Exam Type Selector ─────────────────────────── -->
                    <TextBlock Text="EXAM TYPE"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding ExamTypeOptions}"
                              SelectedItem="{Binding SelectedExamType}"
                              Background="{DynamicResource FieldBg}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderPrimary}"
                              BorderThickness="1"
                              Padding="8,6"
                              FontSize="12"
                              Margin="0,0,0,14" />

                    <Border Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,0,0,14" />

                    <!-- ── EXPOSE Button (big, full width) ──────────── -->
                    <Button Command="{Binding ExposeCommand}"
                            Style="{StaticResource ExposeButtonStyle}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="&#x2622; " FontSize="28" VerticalAlignment="Center" />
                            <TextBlock Text="EXPOSE" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Expose count text -->
                    <TextBlock Text="{Binding ExposeCountText, Mode=OneWay}"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />

                    <!-- ── kV Gauge (visible during expose) ──────────── -->
                    <Border Margin="0,14,0,0"
                            Background="{DynamicResource FieldBg}"
                            CornerRadius="6"
                            Padding="12,8"
                            Visibility="{Binding IsKvActive, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="{Binding KvDisplayText, Mode=OneWay}"
                                           Foreground="{DynamicResource DentalAccent}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Left" />
                                <TextBlock Foreground="{DynamicResource TextSecondary}"
                                           FontSize="10"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom">
                                    <Run Text="Peak: " />
                                    <Run Text="{Binding KvPeak, StringFormat='{}{0:F1}', Mode=OneWay}" />
                                    <Run Text=" kV" />
                                </TextBlock>
                            </Grid>
                            <ProgressBar Height="6"
                                         Value="{Binding KvGaugePercent, Mode=OneWay}"
                                         Minimum="0" Maximum="1"
                                         Foreground="{DynamicResource DentalAccent}"
                                         Background="{DynamicResource BorderPrimary}" />
                        </StackPanel>
                    </Border>

                    <!-- ── Scanline Preview (visible during expose) ──── -->
                    <Border Margin="0,10,0,0"
                            Background="{DynamicResource ImageViewerBg}"
                            CornerRadius="6"
                            Padding="4"
                            Visibility="{Binding IsKvActive, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="4,2,4,4">
                                <TextBlock Text="Scanline Preview"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Left" />
                                <TextBlock Foreground="{DynamicResource TextSecondary}"
                                           FontSize="10"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Right">
                                    <Run Text="{Binding ScanlineCount, Mode=OneWay}" />
                                    <Run Text=" lines" />
                                </TextBlock>
                            </Grid>
                            <Image Source="{Binding ScanlinePreviewImage}"
                                   Height="150"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{DynamicResource BorderPrimary}" Margin="0,14,0,14" />

                    <!-- ── Upload Controls (visible during review) ───── -->
                    <StackPanel Visibility="{Binding IsReviewingImage, Converter={StaticResource BoolToVis}}">
                        <!-- Review status -->
                        <TextBlock Text="{Binding ReviewStatus}"
                                   Foreground="{Binding ReviewStatusColor}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10" />

                        <!-- Confirm & Send -->
                        <Button Command="{Binding ConfirmImageCommand}"
                                Padding="14,12"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Margin="0,0,0,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="{DynamicResource GreenBtnBg}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="{DynamicResource GreenBtnBorder}"
                                            BorderThickness="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource GreenBtnHover}" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource DisabledBg}" />
                                            <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="Confirm &amp; Send" Foreground="White" />
                        </Button>

                        <!-- Retake -->
                        <Button Content="Retake"
                                Command="{Binding RetakeCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="14,10"
                                FontSize="13"
                                Margin="0,0,0,8" />

                        <!-- Retry Upload (visible only when upload failed) -->
                        <Button Content="Retry Upload"
                                Command="{Binding RetryUploadCommand}"
                                Style="{StaticResource OrangeButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Padding="14,10"
                                FontSize="13"
                                Visibility="{Binding IsUploadFailed, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ============================================================ -->
            <!-- Column 2: Image Viewer                                       -->
            <!-- ============================================================ -->
            <Border Grid.Column="2"
                    Background="{DynamicResource ImageViewerBg}"
                    ClipToBounds="True"
                    x:Name="ImageContainer">
                <Grid>
                    <!-- Placeholder when no image -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding ReceivedImage, Converter={StaticResource BoolToVis}, ConverterParameter=invert, FallbackValue=Visible}">
                        <TextBlock Text="&#xE8B8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="64"
                                   Foreground="{DynamicResource BorderPrimary}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="No image received"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0" />
                    </StackPanel>

                    <!-- Interactive image viewer -->
                    <Image x:Name="XrayImage"
                           Source="{Binding DisplayImage}"
                           Stretch="Uniform"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ImageScale"
                                               ScaleX="{Binding ZoomLevel}"
                                               ScaleY="{Binding ZoomLevel}" />
                                <TranslateTransform x:Name="ImageTranslate"
                                                   X="{Binding PanX}"
                                                   Y="{Binding PanY}" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>

                    <!-- Scan progress overlay -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding IsScanInProgress, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xE8B8;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="{DynamicResource ScanProgressFg}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ScanProgressText}" Foreground="{DynamicResource ScanProgressFg}"
                                   FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,0" />
                        <!-- Indeterminate progress bar -->
                        <ProgressBar IsIndeterminate="True" Height="4" Width="200" Margin="0,10,0,0"
                                     Foreground="{DynamicResource ScanProgressFg}" Background="{DynamicResource BorderPrimary}" />
                    </StackPanel>

                    <!-- Preview / Edit button overlay (top-right) -->
                    <Button Content="Preview / Edit"
                            Command="{Binding OpenPreviewEditCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            Padding="14,7"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Cursor="Hand"
                            Visibility="{Binding IsReviewingImage, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{DynamicResource Accent700}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}"
                                        Opacity="0.85">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DentalBlue}" />
                                        <Setter TargetName="border" Property="Opacity" Value="1" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Zoom percentage overlay -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Background="{DynamicResource FieldBg}"
                            CornerRadius="4"
                            Padding="6,3"
                            Opacity="0.85">
                        <TextBlock Text="{Binding ZoomPercentText, Mode=OneWay}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   FontFamily="Consolas" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ── Toast Notification Overlay ──────────────────────────────────── -->
    <ItemsControl ItemsSource="{Binding ActiveToasts}"
                  IsHitTestVisible="False"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,24,24">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border x:Name="ToastBorder"
                        CornerRadius="8"
                        Padding="16,10"
                        Margin="0,0,0,8"
                        MinWidth="260"
                        MaxWidth="400"
                        Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform X="40" />
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <!-- Slide in from right -->
                                    <DoubleAnimation Storyboard.TargetName="ToastBorder"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="40" To="0"
                                                     Duration="0:0:0.25"
                                                     DecelerationRatio="0.6" />
                                    <!-- Fade in -->
                                    <DoubleAnimation Storyboard.TargetName="ToastBorder"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0" To="0.95"
                                                     Duration="0:0:0.25" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource ToastInfo}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Level}" Value="success">
                                    <Setter Property="Background" Value="{DynamicResource ToastSuccess}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="warning">
                                    <Setter Property="Background" Value="{DynamicResource ToastWarning}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Level}" Value="error">
                                    <Setter Property="Background" Value="{DynamicResource ToastError}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Message}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
    </Grid>
</Window>
