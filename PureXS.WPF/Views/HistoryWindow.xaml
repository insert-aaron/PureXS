<Window x:Class="PureXS.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PureXS — Patient History"
        Width="800" Height="600"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <!-- Dark scrollbar style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource FieldBg}" />
            <Setter Property="Width" Value="8" />
            <Setter Property="MinWidth" Value="8" />
        </Style>

        <!-- List item hover style for patients -->
        <Style x:Key="PatientListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource BorderPrimary}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBg}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SelectedBg}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource DentalAccent}" />
                                <Setter TargetName="border" Property="BorderThickness" Value="0,0,0,2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Session list item style -->
        <Style x:Key="SessionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource BorderPrimary}"
                                BorderThickness="0,0,0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBg}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource CardBg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small button style -->
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ToolbarBtnBg}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource ToolbarBtnBorder}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ToolbarBtnHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header button -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource AccentBtnBg}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource BorderPrimary}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBtnHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelBg}"
                Padding="16,12"
                BorderBrush="{DynamicResource BorderPrimary}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Patient History"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Foreground="{DynamicResource TextSecondary}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0">
                        <Run Text="{Binding Patients.Count, Mode=OneWay}" />
                        <Run Text=" patients" />
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource HeaderButtonStyle}" />
            </Grid>
        </Border>

        <!-- Main content: two columns -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Patient list -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource BorderPrimary}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Column header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource FieldBg}"
                            Padding="12,8"
                            BorderBrush="{DynamicResource BorderPrimary}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="50" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="PATIENT"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="10"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1"
                                       Text="LAST SCAN"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="10"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2"
                                       Text="#"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </Border>

                    <ListBox ItemsSource="{Binding Patients}"
                             SelectedItem="{Binding SelectedPatient}"
                             ItemContainerStyle="{StaticResource PatientListItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Foreground="{DynamicResource DentalAccent}"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                        <Run Text="{Binding SessionCount, Mode=OneWay}" />
                                        <Run Text=" scans" />
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding LastScan}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right: Session details -->
            <Border Grid.Column="1"
                    Background="{DynamicResource WindowBg}">
                <DockPanel>
                    <!-- Session header -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource FieldBg}"
                            Padding="14,8"
                            BorderBrush="{DynamicResource BorderPrimary}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="10"
                                       FontWeight="SemiBold">
                                <Run Text="SESSIONS FOR: " />
                                <Run Text="{Binding SelectedPatient.DisplayName, Mode=OneWay, FallbackValue='(none selected)'}"
                                     Foreground="{DynamicResource TextPrimary}" />
                            </TextBlock>
                            <Button Grid.Column="1"
                                    Content="Open Folder"
                                    Command="{Binding OpenFolderCommand}"
                                    CommandParameter="{Binding SelectedPatient}"
                                    Style="{StaticResource SmallButtonStyle}" />
                        </Grid>
                    </Border>

                    <!-- No sessions placeholder -->
                    <TextBlock Text="Select a patient to view sessions"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Session list -->
                    <ListBox ItemsSource="{Binding SelectedSessions}"
                             ItemContainerStyle="{StaticResource SessionListItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPatient}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <!-- Timestamp -->
                                        <TextBlock Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold">
                                            <Run Text="{Binding Timestamp, Mode=OneWay}" />
                                        </TextBlock>

                                        <!-- Details row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Border Background="{DynamicResource ExamBadgeBg}"
                                                    CornerRadius="3"
                                                    Padding="6,2"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding ExamType}"
                                                           Foreground="{DynamicResource ExamBadgeFg}"
                                                           FontSize="11" />
                                            </Border>
                                            <TextBlock Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding KvPeak, StringFormat='{}{0:F1} kV', Mode=OneWay}" />
                                                <Run Text="  |  " />
                                                <Run Text="{Binding Scanlines, Mode=OneWay}" />
                                                <Run Text=" scanlines" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Image file -->
                                        <TextBlock Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Margin="0,3,0,0"
                                                   Text="{Binding ImageFile, FallbackValue='(no image)'}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <Button Content="View Image"
                                                Command="{Binding DataContext.ViewImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SmallButtonStyle}"
                                                Margin="0,0,6,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
